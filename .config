# This is an empty file, please overwrite it after generating the .config file with the source code
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# 1. Driver Switch (6 Port RJ45 & 2 Port SFP)
CONFIG_PACKAGE_kmod-dsa-mv88e6xxx=y
CONFIG_PACKAGE_kmod-dsa-core=y
CONFIG_PACKAGE_kmod-intel-igb=y
CONFIG_PACKAGE_kmod-intel-ixgbe=y

# 2. Driver USB 3.0 (2 Port USB)
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_kmod-usb-core=y

# 3. Driver Wi-Fi Bawaan (Atheros/Intel Wireless)
CONFIG_PACKAGE_kmod-ath10k-smallbuffers=y
CONFIG_PACKAGE_ath10k-firmware-qca988x=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y

# 4. Driver WWAN / Slot 2 Kartu SIM (Modem LTE Internal)
CONFIG_PACKAGE_kmod-usb-net-qmi-wwan=y
CONFIG_PACKAGE_kmod-usb-serial-qualcomm=y
CONFIG_PACKAGE_uqmi=y

# 5. Aplikasi Web Menu & OpenClash
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-compat=y
